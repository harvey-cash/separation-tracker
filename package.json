{
  "name": "separation-tracker",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "workspaces": [
    "apps/brave-paws-landing",
    "apps/brave-paws-app",
    "apps/brave-paws-server"
  ],
  "scripts": {
    "dev": "npm run app:dev",
    "build": "npm run app:build && npm run landing:build && npm run server:build",
    "preview": "npm run app:preview",
    "test": "npm run app:test && npm run server:test",
    "lint": "npm run app:lint && npm run server:lint",
    "test:e2e": "npm run app:test:e2e",
    "clean": "npm run app:clean && npm run landing:clean && npm run server:clean",
    "app:dev": "npm run dev --workspace brave-paws-app",
    "app:build": "npm run build --workspace brave-paws-app",
    "app:preview": "npm run preview --workspace brave-paws-app",
    "app:test": "npm run test --workspace brave-paws-app",
    "app:lint": "npm run lint --workspace brave-paws-app",
    "app:test:e2e": "npm run test:e2e --workspace brave-paws-app",
    "app:clean": "npm run clean --workspace brave-paws-app",
    "landing:dev": "npm run dev --workspace brave-paws-landing",
    "landing:build": "npm run build --workspace brave-paws-landing",
    "landing:preview": "npm run preview --workspace brave-paws-landing",
    "landing:clean": "npm run clean --workspace brave-paws-landing",
    "server:dev": "npm run dev --workspace brave-paws-server",
    "server:build": "npm run build --workspace brave-paws-server",
    "server:lint": "npm run lint --workspace brave-paws-server",
    "server:start": "npm run start --workspace brave-paws-server",
    "server:test": "npm run test --workspace brave-paws-server",
    "server:clean": "npm run clean --workspace brave-paws-server"
  }
}
